  "data_model": {
    "notes": [
      "Bestehende Haus-/Grundstücksdaten nicht sofort löschen, aber UI-seitig deaktivieren.",
      "Alle Beträge in Cent oder Decimal speichern, konsistent mit bestehendem Code.",
      "Hold-Entscheidungen erzeugen keinen Order-Datensatz mit Gebühr, aber einen Decision-/Journal-Datensatz."
    ],
    "enums": {
      "decision_action": [
        "buy",
        "sell",
        "hold"
      ],
      "reason_type": [
        "long_term_growth",
        "reduce_risk",
        "not_enough_information",
        "diversify",
        "own_reason"
      ],
      "daily_task_status": [
        "open",
        "completed",
        "locked",
        "skipped_without_penalty"
      ],
      "asset_type": [
        "stock",
        "etf"
      ]
    },
    "tables": {
      "daily_plans": {
        "purpose": "Tagesplan pro Nutzer",
        "columns": {
          "id": "uuid primary key",
          "user_id": "uuid not null",
          "date": "date not null",
          "learning_module_id": "uuid nullable",
          "market_asset_id": "uuid nullable",
          "decision_required": "boolean default true",
          "learning_completed_at": "timestamp nullable",
          "market_viewed_at": "timestamp nullable",
          "decision_completed_at": "timestamp nullable",
          "created_at": "timestamp not null",
          "updated_at": "timestamp not null"
        },
        "constraints": [
          "unique(user_id, date)"
        ]
      },
      "trade_decisions": {
        "purpose": "Virtuelle Übungsentscheidungen inklusive Halten",
        "columns": {
          "id": "uuid primary key",
          "user_id": "uuid not null",
          "asset_id": "uuid not null",
          "daily_plan_id": "uuid nullable",
          "action": "decision_action not null",
          "quantity": "integer not null default 0",
          "virtual_price_cents": "integer nullable",
          "fee_cents": "integer not null default 0",
          "reason_type": "reason_type not null",
          "reason_text": "text nullable",
          "created_at": "timestamp not null"
        },
        "constraints": [
          "if action is hold then quantity = 0 and fee_cents = 0",
          "if action is buy or sell then quantity > 0 and fee_cents = 500",
          "quantity must be integer"
        ]
      },
      "decision_journal": {
        "purpose": "Reflexionshistorie für Nutzer",
        "columns": {
          "id": "uuid primary key",
          "user_id": "uuid not null",
          "trade_decision_id": "uuid not null",
          "summary_text": "text not null",
          "created_at": "timestamp not null"
        }
      },
      "learning_module_asset_links": {
        "purpose": "Verknüpft Lernmodule mit passenden Markt-Labor-Aufgaben",
        "columns": {
          "id": "uuid primary key",
          "learning_module_id": "uuid not null",
          "asset_id": "uuid not null",
          "prompt_de": "text nullable",
          "prompt_en": "text nullable"
        }
      },
      "user_weekly_training_status": {
        "purpose": "Optionaler Cache für Wochenübersicht",
        "columns": {
          "id": "uuid primary key",
          "user_id": "uuid not null",
          "week_start_date": "date not null",
          "mon_status": "daily_task_status",
          "tue_status": "daily_task_status",
          "wed_status": "daily_task_status",
          "thu_status": "daily_task_status",
          "fri_status": "daily_task_status",
          "sat_status": "daily_task_status",
          "sun_status": "daily_task_status"
        }
      }
    }
  },
